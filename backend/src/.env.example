# =============================================
#  CRUMBSKATE - Variables de entorno
#  Copiá este archivo como .env y completalo
#  NUNCA subas .env a GitHub
# =============================================

# Servidor
PORT=3000
NODE_ENV=development

# Base de datos MySQL (Railway te da estos valores)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password_aqui
DB_NAME=crumbskate

# JWT - generá una clave larga y aleatoria (mínimo 32 caracteres)
JWT_SECRET=cambia_esto_por_una_clave_muy_larga_y_secreta_123
JWT_EXPIRES_IN=7d

# CORS - URL del frontend (Vercel en producción)
CORS_ORIGIN=http://localhost:5500
